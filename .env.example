# Copiar a .env y completar los valores locales
# .env está en .gitignore — nunca commitear secretos

# Base de datos
DB_HOST=localhost
DB_PORT=5432
DB_NAME=hornet_imports
DB_USER=postgres
DB_PASSWORD=postgres

# JWT (mínimo 32 caracteres aleatorios)
JWT_SECRET=cambiar_por_secreto_de_al_menos_32_caracteres_aleatorios

# Google OAuth
GOOGLE_CLIENT_ID=tu_client_id.apps.googleusercontent.com

# Email — Resend SMTP
RESEND_SMTP_PASSWORD=re_XXXXXXXXXXXXXXXX
EMAIL_FROM=noreply@hornetimports.com
EMAIL_ADMIN=admin@hornetimports.com

# Mercado Pago
MP_ACCESS_TOKEN=APP_USR-XXXXXXXXXXXXXXXX
MP_WEBHOOK_SECRET=

# Cloudinary
CLOUDINARY_CLOUD_NAME=tu_cloud_name
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# Pagos manuales
USDT_WALLET_ADDRESS=tu_direccion_TRC20
TRANSFERENCIA_CBU=
TRANSFERENCIA_ALIAS=
TRANSFERENCIA_BANCO=
TRANSFERENCIA_TITULAR=

# App
APP_BASE_URL=http://localhost:8080
FRONTEND_URL=http://localhost:5173
